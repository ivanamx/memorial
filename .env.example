# =============================================================================
# MEMORIALES CELESTIALES — ejemplo de variables de entorno (PRODUCCIÓN)
# =============================================================================
# Copia este archivo a `.env` en el servidor y rellena los valores reales.
# No subas `.env` al repositorio (debe estar en .gitignore).
# =============================================================================

# --- Aplicación ---
NODE_ENV=production
PORT=3000
# URL pública HTTPS de tu API (webhooks de Stripe y Meta deben apuntar aquí)
PUBLIC_URL=https://api.tudominio.com

# --- PostgreSQL ---
# Una sola URL (recomendado con PgBouncer o conexión directa):
DATABASE_URL=postgresql://postgres:password@localhost:5432/memoriales_celestiales

# Si prefieres variables separadas en lugar de DATABASE_URL, úsalas en tu código:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=memorial_app
# PGPASSWORD=cambiar_por_secreto
# PGDATABASE=memoriales_celestiales

# true si tu proveedor exige SSL (ej. RDS, Neon, Supabase)
DATABASE_SSL=false

# --- Stripe ---
# Clave secreta (Dashboard Stripe → API keys); formato sk_live_... o sk_test_...
STRIPE_SECRET_KEY=
# Clave pública; formato pk_live_... o pk_test_...
STRIPE_PUBLISHABLE_KEY=
# Secreto del endpoint de webhook (Dashboard Stripe → Webhooks → Signing secret); formato whsec_...
STRIPE_WEBHOOK_SECRET=

# Price IDs (Stripe Dashboard → Catálogo de productos → cada Price en MXN, pago único).
# Los importes reales los defines en Stripe; aquí solo van los IDs price_... para el código.

# Paquete único — $800 MXN
STRIPE_PRICE_ID_PAQUETE_UNICO=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Extras — +$250 QR lápida | +$200 inglés | +$300 express (sin USB ni video extendido; no se ofrecen)
STRIPE_PRICE_ID_EXTRA_QR_LAPIDA=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_EXTRA_VERSION_INGLES=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_EXTRA_ENTREGA_EXPRESS=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Revisión adicional (ej. $300 MXN si coincide con REVISION_ADICIONAL_PRECIO_MXN)
STRIPE_PRICE_ID_REVISION_ADICIONAL=price_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Meta / WhatsApp Cloud API ---
# ID del número de WhatsApp Business (Meta for Developers → tu app → WhatsApp → API setup)
WHATSAPP_PHONE_NUMBER_ID=
# Token de acceso de larga duración o del System User (no el de prueba en prod)
WHATSAPP_ACCESS_TOKEN=
# Cadena que tú defines; Meta la envía al verificar el webhook GET
WHATSAPP_VERIFY_TOKEN=
# App Secret de la app Meta (para validar firma X-Hub-Signature-256 en webhooks)
WHATSAPP_APP_SECRET=

# --- Flujo del bot (alineado a PLANTILLAS) ---
# Horas sin mensaje del cliente antes de cierre por inactividad
BOT_INACTIVITY_HOURS=24
# Comando interno del asesor para reanudar (mismo texto que en el .ini)
BOT_CONTINUE_COMMAND=CONTINUAR BOT

# --- Enlaces que van en mensajes al cliente ---
GOOGLE_BUSINESS_REVIEW_URL=https://g.page/r/xxxxxxxx/review

# --- Negocio (opcional si tu código no lee solo desde BD) ---
# Precio en MXN para revisión adicional (debe coincidir con el Price de Stripe si cobras por ahí)
# REVISION_ADICIONAL_PRECIO_MXN=300

# --- Almacenamiento de medios (fotos, audio, video) — servidor propio ---
# Directorio en disco donde el bot guarda los binarios; en BD solo va la ruta/URL en archivos.url_archivo
MEDIA_STORAGE_PATH=/var/memoriales/media
# Si nginx/tu API sirve esos archivos por HTTPS (opcional)
# PUBLIC_MEDIA_BASE_URL=https://api.tudominio.com/media

# --- Almacenamiento en nube (opcional; solo si dejas de usar solo disco) ---
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=memoriales-media
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# --- Alertas internas (opcional; si AYUDA / escalación deben avisar por correo) ---
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_FROM=noreply@tudominio.com
# ALERT_EMAIL_TO=equipo@tudominio.com

# --- Otros (opcional) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# LOG_LEVEL=info
